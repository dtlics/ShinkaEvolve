# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Two ways shinka picks this up:
# 1. ``shinka.env.load_shinka_dotenv`` automatically loads ``.env`` next to
#    this file (the shinkaevolve repo root) AND the launch directory's
#    ``.env`` if one exists. Launch-dir values override repo-root values.
# 2. Hydra config + the shinka launcher don't auto-load — set env vars
#    via shell ``export`` if you bypass the helper.
#
# After this collapse (collapsed-agent branch), the repo root .env is the
# canonical location. Outer-repo .env files are no longer used.

# === Azure OpenAI: main chat/reasoning endpoint ============================
# Resource: dtlics2000shinka, region: East US 2, project "Shinka".
# Endpoint must be the BARE resource URL — shinka appends /openai/v1.
AZURE_OPENAI_API_KEY=
AZURE_API_ENDPOINT=https://dtlics2000shinka.openai.azure.com
AZURE_API_VERSION=preview

# Embedding deployments use a separate api_version since /openai/v1
# doesn't serve the embeddings path. Defaults to a stable GA revision
# if unset (shinka/llm/client.py).
AZURE_EMBEDDING_API_VERSION=2024-10-21

# Deployments available in the "Shinka" Foundry project (all Global Standard):
#   azure-gpt-5.4-pro    -> deployment "gpt-5.4-pro"
#   azure-gpt-5.5        -> deployment "gpt-5.5"
#   azure-gpt-5.4-mini   -> deployment "gpt-5.4-mini"
#   azure-gpt-5.3-codex  -> deployment "gpt-5.3-codex"
#   azure-text-embedding-3-small -> deployment "text-embedding-3-small"
#   azure-text-embedding-3-large -> deployment "text-embedding-3-large"


# === Azure DR: deep-research endpoint (phase 2 of research-grounding) ======
# SEPARATE Azure resource from the main endpoint above. Provisioned in the
# user's "dtlics2000-4351" Foundry project for ``o3-deep-research``.
# Used by shinka/llm/agent/dr_client.py — see also shinka/core/config.py
# under ``enable_deep_research``.
#
# The endpoint can be the bare resource path
# (``https://<resource>.services.ai.azure.com/api/projects/<project>``)
# OR with ``/openai/v1`` appended OR the full ``/openai/v1/responses``
# URL — _build_dr_base_url normalizes all three.
AZURE_DR_API_KEY=
AZURE_DR_ENDPOINT=https://dtlics2000-4351-resource.services.ai.azure.com/api/projects/dtlics2000-4351
AZURE_DR_API_VERSION=preview

# Deployment name (what shinka passes as ``model=`` to responses.create).
# The framework default ``o3-deep-research`` matches a typical Foundry
# deployment name; if you named the deployment differently in your
# Foundry project, override ``evo.dr_model`` in your task config.


# === Other providers (optional) ============================================
# Non-OpenAI providers still work via shinka's legacy path (Anthropic,
# Gemini, DeepSeek, etc.). Set keys here if you use them — leave blank
# otherwise. The agentic path routes Azure/OpenAI through the agents SDK;
# other providers fall through to ``query_async`` and ignore tool calls.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
