# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Loaded automatically by shinka.env.load_shinka_dotenv from this directory
# (the package root) and from the launch CWD. Launch-dir values override.

# === Azure OpenAI: main chat/reasoning endpoint ============================
# Bare resource URL — shinka appends /openai/v1 (see
# shinka.llm.client._build_azure_base_url).
AZURE_OPENAI_API_KEY=
AZURE_API_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_API_VERSION=preview

# /openai/v1 doesn't serve the embeddings path, so embeddings use a separate
# stable api-version. Defaults to a recent GA revision if unset; pin here
# if a deployment requires a specific date.
AZURE_EMBEDDING_API_VERSION=2024-10-21


# === Azure DR: o3-deep-research endpoint ==================================
# SEPARATE Azure resource from the main endpoint above. Same umbrella-URL
# form (https://<resource>.openai.azure.com) — the dr_client appends
# /openai/v1 the same way the main client does. Both URL surfaces work;
# the AI Services project URL is also accepted, normalized by
# _build_dr_base_url.
AZURE_DR_API_KEY=
AZURE_DR_ENDPOINT=https://<your-dr-resource>.openai.azure.com
AZURE_DR_API_VERSION=preview

# The DR deployment defaults to ``o3-deep-research`` (a typical Foundry deployment
# name). If yours differs, pass ``model`` in the deep_research payload or edit
# orchestrator/scripts/deep_research.py.
