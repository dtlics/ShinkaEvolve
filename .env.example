# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Shinka loads this file from the launch directory (CWD when running shinka_run).
# See: shinkaevolve/shinka/env.py and shinkaevolve/shinka/llm/client.py

# === Azure OpenAI ===
# Endpoint should be the base resource URL, e.g. https://my-resource.openai.azure.com
# Shinka appends `openai/v1/` automatically.
AZURE_OPENAI_API_KEY=
AZURE_API_ENDPOINT=
AZURE_API_VERSION=2024-12-01-preview

# Use models in shinka configs as `azure-<deployment-name>`,
# e.g. if your deployment is named `gpt-4o-mini`, set `llm_models: ["azure-gpt-4o-mini"]`.

# === Other providers (optional, leave blank if unused) ===
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
